# Copy this file to .env and add local-only values here.
VITE_APP_NAME=Halfway

# Server-side key: enable Places API (New), Routes API, and Geocoding API.
# Restrict this key to those APIs and never commit the real value.
GOOGLE_MAPS_API_KEY=your_server_google_maps_key

# Optional browser key for the Google location autocomplete widget.
# Restrict this key by website origin and to Maps JavaScript API + Places API.
VITE_GOOGLE_MAPS_API_KEY=your_browser_google_maps_key

API_PORT=8787
